<h2>Currency Converter</h2>

<form action="convert" method="post">

Amount (INR):
<input type="text" name="amount"><br><br>

<select name="type">
<option value="usd">INR to USD</option>
<option value="eur">INR to EUR</option>
<option value="gbp">INR to GBP</option>
</select>

<br><br>

<input type="submit" value="Convert">

</form>

</body>
</html>
####Currency converter.jsp

package com.currency;

import java.io.*;
import javax.servlet.*;
import javax.servlet.http.*;

public class ConverterServlet extends HttpServlet {

protected void doPost(HttpServletRequest req, HttpServletResponse res)
throws ServletException, IOException {

double amount = Double.parseDouble(req.getParameter("amount"));
String type = req.getParameter("type");

double result = 0;

if(type.equals("usd"))
result = amount * 0.012;

else if(type.equals("eur"))
result = amount * 0.011;

else if(type.equals("gbp"))
result = amount * 0.0095;

PrintWriter out = res.getWriter();
out.println("<h2>Converted Amount = " + result + "</h2>");

}
}#servlet .java


